# Server-only (Vercel / api/gemini). Set in Vercel Project → Settings → Environment Variables.
# Local: copy to .env.local for `vercel dev`, or export GEMINI_API_KEY in the shell.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_server_side_key_here

# Optional: when using `npm run dev` (Vite) + `vercel dev` on another port
# VERCEL_DEV_API_URL=http://127.0.0.1:3000
