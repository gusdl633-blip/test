{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "^/api/saju$",
      "dest": "/api/saju.py"
    },
    {
      "src": "^/api/gemini$",
      "dest": "/api/gemini.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^(?!/api).*$",
      "dest": "/"
    }
  ]
}
